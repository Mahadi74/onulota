{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**", "node_modules/sharp/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "installCommand": "npm install --platform=linux --arch=x64 sharp && npm install",
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 * * * *"
    }
  ]
}

