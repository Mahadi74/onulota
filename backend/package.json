{
  "name": "onulota-backend",
  "version": "1.0.0",
  "description": "onulota eCommerce Platform Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_EXTRA_CA_CERTS=/etc/ssl/cert.pem nodemon src/index.ts",
    "build": "tsc",
    "start": "NODE_EXTRA_CA_CERTS=/etc/ssl/cert.pem node dist/index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint . --ext .ts",
    "seed": "NODE_EXTRA_CA_CERTS=/etc/ssl/cert.pem ts-node src/scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
